# ===== XMAIL Platform — copy to .env and fill in =====

# --- Server ---
PORT=8080
# Public URL of this server (used in links). e.g. https://xmail.yourdomain.com
BASE_URL=http://localhost:8080
# Long random string — encrypts user email credentials + signs sessions. NEVER change after launch.
SERVER_SECRET=change_me_to_a_long_random_string

# --- AI (required) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- The ONE official XMAIL Telegram bot (from @BotFather) ---
TELEGRAM_BOT_TOKEN=123456:ABC...
# Your bot's username without @ — used to build the magic link t.me/<username>?start=CODE
TELEGRAM_BOT_USERNAME=XmailBot

# --- "Sign in with Google" (optional — leave blank to hide the button) ---
# OAuth 2.0 Client ID (Web application) from console.cloud.google.com/apis/credentials.
# Add this app's URL(s) under "Authorized JavaScript origins" (no path, no trailing slash).
GOOGLE_CLIENT_ID=

# --- WhatsApp via Twilio (optional — leave blank to disable) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Behaviour ---
POLL_SECONDS=60
PUSH_NORMAL=true
DIGEST_HOUR=8

# --- Optional: voice-note replies (WhatsApp) — transcription via OpenAI Whisper ---
OPENAI_API_KEY=

# --- Optional: the shared "forward anything to XMAIL" inbox ---
# Any email forwarded here by a signed-up user gets processed to their chat.
FORWARD_MAIL_USER=
FORWARD_MAIL_PASSWORD=
FORWARD_IMAP_HOST=imap.gmail.com
FORWARD_IMAP_PORT=993

# --- Silence catcher: nudge after this many days without a reply ---
NUDGE_DAYS=3

# ===== OKX.AI ASP layer =====
OKX_NETWORK=mock                 # mock | testnet | mainnet
OKX_WALLET_ADDRESS=              # XMAIL's Agentic Wallet address (from OnchainOS)
OKX_WALLET_KEY=                  # its signing key — SECRET
OKX_TOKEN=USDT
OKX_CHAIN_ID=196
# real onchain verification (used when OKX_NETWORK=testnet or mainnet)
XLAYER_RPC_URL=https://rpc.xlayer.tech
USDT_CONTRACT_ADDRESS=0x1E4a5963aBFD975d8c9021ce480b42188849D41d
MIN_CONFIRMATIONS=1
PRICE_TRIAGE=0.005
PRICE_DRAFT=0.02
PRICE_FILL=0.02
SCAM_CHECK_ENABLED=true
SCAM_CHECK_ENDPOINT=             # blank = bundled mock ASP; or a real security ASP URL
SCAM_CHECK_MAX_PRICE=0.002
SCAM_CHECK_DAILY_CAP=1.0
