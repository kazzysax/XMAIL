# ===== XMAIL Platform — copy to .env and fill in =====

# --- Server ---
PORT=8080
# Public URL of this server (used in links). e.g. https://xmail.yourdomain.com
BASE_URL=http://localhost:8080
# Long random string — encrypts user email credentials + signs sessions. NEVER change after launch.
SERVER_SECRET=change_me_to_a_long_random_string

# --- AI (required) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- The ONE official XMAIL Telegram bot (from @BotFather) ---
TELEGRAM_BOT_TOKEN=123456:ABC...
# Your bot's username without @ — used to build the magic link t.me/<username>?start=CODE
TELEGRAM_BOT_USERNAME=XmailBot

# --- "Sign in with Google" (optional — leave blank to hide the button) ---
# OAuth 2.0 Client ID (Web application) from console.cloud.google.com/apis/credentials.
# Add this app's URL(s) under "Authorized JavaScript origins" (no path, no trailing slash).
GOOGLE_CLIENT_ID=

# --- Outbound mail sending via Resend (https://resend.com) ---
# Required on hosts like Render that block outbound SMTP ports (25/465/587).
# Leave RESEND_API_KEY blank to send via direct SMTP instead (works on VPS hosts).
RESEND_API_KEY=
# Must be on a domain you've verified in Resend. Use onboarding@resend.dev for testing
# (only delivers to your own Resend account email until a domain is verified).
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=XMAIL

# --- WhatsApp via Twilio (optional — leave blank to disable) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Behaviour ---
POLL_SECONDS=60
PUSH_NORMAL=true
DIGEST_HOUR=8

# --- Optional: voice-note replies (WhatsApp) — transcription via OpenAI Whisper ---
OPENAI_API_KEY=

# --- Optional: the shared "forward anything to XMAIL" inbox ---
# Any email forwarded here by a signed-up user gets processed to their chat.
FORWARD_MAIL_USER=
FORWARD_MAIL_PASSWORD=
FORWARD_IMAP_HOST=imap.gmail.com
FORWARD_IMAP_PORT=993

# --- Silence catcher: nudge after this many days without a reply ---
NUDGE_DAYS=3

# ===== OKX.AI ASP layer =====
OKX_NETWORK=mock                 # mock | testnet | mainnet — Tier 2 (buyer) only
OKX_WALLET_ADDRESS=              # XMAIL's Agentic Wallet address (from OnchainOS)
OKX_WALLET_KEY=                  # its signing key — SECRET (Tier 2 buyer only)
OKX_TOKEN=USDT
OKX_CHAIN_ID=196
# --- Official OKX x402 Facilitator credentials (Tier 1 seller) ---
# From the OKX Developer Portal. Required for XMAIL's paid services to
# verify/settle real payments as a registered A2MCP ASP.
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
# CAIP-2 network id for Tier 1 payments: eip155:1952 = X Layer testnet
# (default, safe for testing), eip155:196 = X Layer mainnet (real USDT).
OKX_NETWORK_ID=eip155:1952
PRICE_TRIAGE=0.005
PRICE_DRAFT=0.02
PRICE_FILL=0.02
PRICE_REPORT=0.05

# Tier 2 (XMAIL hiring a scam-check agent to vet suspicious mail) — later
# feature, not wired up for launch. Left disabled.
SCAM_CHECK_ENABLED=false
SCAM_CHECK_ENDPOINT=             # blank = bundled mock ASP; or a real security ASP URL
SCAM_CHECK_MAX_PRICE=0.002
SCAM_CHECK_DAILY_CAP=1.0
